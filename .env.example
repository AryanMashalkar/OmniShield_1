# OmniShield backend configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real secrets.

# Shared API key protecting state-changing SOAR endpoints (block/unblock IP).
# Must match VITE_OMNISHIELD_API_KEY in frontend/.env.
# If left unset, the backend generates a random key per run and prints it.
OMNISHIELD_API_KEY=change-me-to-a-long-random-string

# Comma-separated CORS allow-list (no wildcard in production).
OMNISHIELD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama models.
OMNISHIELD_LLM_MODEL=llama3.1:8b
OMNISHIELD_EMBED_MODEL=nomic-embed-text

# Detection thresholds (rolling z-score).
OMNISHIELD_BASELINE_WINDOW=40
OMNISHIELD_Z_THRESHOLD=3.0
OMNISHIELD_MIN_BASELINE=10

# Live stream: "simulate" (NSL-KDD normals + scripted exfil) or
# "replay" (replay real labeled NSL-KDD records incl. attacks).
OMNISHIELD_STREAM_MODE=simulate
OMNISHIELD_STREAM_INTERVAL=2.0

# Human-in-the-loop: require explicit analyst confirmation before blocking.
OMNISHIELD_SOAR_REQUIRE_CONFIRMATION=true
